{
  "name": "ikiru-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm test",
    "test": "node --test tests/*.test.js",
    "track:fresh24h": "node scripts/track-fresh24h.js",
    "cleanup:health": "node scripts/cleanup-health.js",
    "dev": "nodemon index.js",
    "dev:vercel": "vercel dev --yes --listen 3000",
    "prepare": "husky"
  },
  "nodemonConfig": {
    "watch": [
      "api",
      "lib",
      "index.js"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules",
      "tests",
      "*.test.js"
    ],
    "delay": 1000
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@upstash/redis": "^1.36.2",
    "@vercel/functions": "^3.4.3",
    "axios": "1.13.5",
    "bottleneck": "^2.19.5",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "date-fns": "^4.1.0",
    "discord-interactions": "^4.4.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "lodash-es": "^4.18.1",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "rate-limiter-flexible": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ]
  }
}
