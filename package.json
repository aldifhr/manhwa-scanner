{
  "name": "manhwa-scrap-discord",
  "version": "1.0.0",
  "description": "Discord bot to scrape and notify updates from manhwa/manga sources.",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm run type-check",
    "type-check": "tsc --noEmit",
    "track:fresh24h": "tsx scripts/track-fresh24h.ts",
    "cleanup:health": "tsx scripts/cleanup-health.ts",
    "test:hexpire": "tsx scripts/test-hexpire.ts",
    "test:daily": "tsx scripts/test-daily-stats.ts",
    "dev": "tsx watch index.ts",
    "dev:vercel": "vercel dev --yes --listen 3000",
    "prepare": "husky"
  },
  "nodemonConfig": {
    "watch": [
      "api",
      "lib",
      "index.ts"
    ],
    "ext": "ts,js,json",
    "ignore": [
      "node_modules"
    ],
    "delay": 1000
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.36.2",
    "@vercel/functions": "^3.4.3",
    "axios": "1.13.5",
    "bottleneck": "^2.19.5",
    "date-fns": "^4.1.0",
    "discord-interactions": "^4.4.0",
    "express": "^5.2.1",
    "node-html-parser": "^7.1.0",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/node": "^25.6.0",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "knip": "^6.4.1",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ]
  }
}
