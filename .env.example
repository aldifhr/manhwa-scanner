# ==========================================
# Ikiru Bot - Environment Variables
# ==========================================

# ------------------------------------------
# Discord Configuration (Required)
# ------------------------------------------
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_PUBLIC_KEY=your_discord_public_key_here
DISCORD_OWNER_ID=your_discord_user_id_here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx  # Optional, for error logging

# ------------------------------------------
# Redis Configuration (Required)
# Uses Upstash Redis or any Redis-compatible service
# ------------------------------------------
REDIS_URL=rediss://default:password@host:port

# ------------------------------------------
# Security & Authentication (Required)
# ------------------------------------------
CRON_SECRET=your_random_cron_secret_key_here
DASHBOARD_SESSION_SECRET=your_random_session_secret_here
DASHBOARD_PASSWORD=your_secure_dashboard_password_here

# ------------------------------------------
# Server Configuration (Optional)
# ------------------------------------------
PORT=3000
NODE_ENV=production  # development | production
LOG_LEVEL=info       # debug | info | warn | error

# ------------------------------------------
# Cache TTL Configuration (Optional - has defaults)
# ------------------------------------------
CACHE_TTL_SEC=60           # General cache TTL
RECENT_CACHE_SEC=180       # Recent chapters cache
LOGS_CACHE_SEC=300         # Cron logs cache
STATUS_CACHE_SEC=60        # Status page cache
WHITELIST_CACHE_SEC=300    # Whitelist cache
INCIDENT_CACHE_TTL=300     # Incidents cache
SESSION_TTL_SECONDS=43200  # Dashboard session (12 hours)

# ------------------------------------------
# API & Timeout Configuration (Optional - has defaults)
# ------------------------------------------
API_TIMEOUT_MS=30000            # API request timeout (30s)
CRON_MAX_DURATION_SEC=300       # Cron max duration (5 min) - Vercel Pro only
HEALTH_CHECK_MAX_DURATION_SEC=300
HEALTH_CACHE_TTL_MS=60000       # Health check cache (1 min)

# ------------------------------------------
# Rate Limiting (Optional - has defaults)
# ------------------------------------------
RATE_LIMIT_WINDOW_MS=60000      # 1 minute
RATE_LIMIT_MAX_REQUESTS=100     # 100 requests per window

# ------------------------------------------
# Scraper & Cron Configuration (Optional)
# ------------------------------------------
CRON_DEBUG=false                # Enable debug logging for cron
CHANNEL_VALIDATION_CONCURRENCY=8  # Concurrent channel validations
SOURCE_FAIL_THRESHOLD=3         # Consecutive failures before cooldown
SOURCE_COOLDOWN_SECONDS=1800    # 30 minutes cooldown

# ------------------------------------------
# Source URLs (Optional - has defaults)
# ------------------------------------------
IKIRU_BASE_URL=https://02.ikiru.wtf/
SECONDARY_SOURCE_URL=https://api.shngm.io

# ------------------------------------------
# Scraper Timeout & FastCron Safety Configs (Optional - has defaults)
# ------------------------------------------
# Ensure TOTAL_TIMEOUT leaves about ~10,000ms margin for dispatcher to finish 
# gracefully before the 28-second Vercel max limit kills the execution.
IKIRU_REQUEST_TIMEOUT_MS=12000
IKIRU_TOTAL_TIMEOUT_MS=17500
IKIRU_MAX_RETRIES=1
IKIRU_MAX_CHAPTERS=5

SECONDARY_REQUEST_TIMEOUT_MS=9000
SECONDARY_MAX_RETRIES=1
SECONDARY_DIRECT_FALLBACK_MAX_URLS=50

